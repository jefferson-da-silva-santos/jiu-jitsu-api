# ============================================
# COMBATE+ — VARIÁVEIS DE AMBIENTE
# Copie para .env e preencha com seus valores
# ============================================

NODE_ENV=development
PORT=3333
API_PREFIX=/api/v1

# Neon PostgreSQL
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/combateplus?sslmode=require"

# JWT — use strings longas e aleatórias
JWT_SECRET=sua_chave_jwt_super_secreta_minimo_32_caracteres
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=sua_chave_refresh_super_secreta_minimo_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# CORS — domínio do frontend
CORS_ORIGIN=http://localhost:5173

# Uploads
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=./uploads

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Monetização
PLATFORM_FEE_CENTS=250
CASHBACK_PERCENT=10
